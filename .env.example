# Copy this file to `.env.local` for local overrides.
# Do not commit real credentials or machine-specific values.

# URL for the local Gemma/Ollama container that serves the model.
GEMMA_BASE_URL=http://127.0.0.1:11434

# Small default that is realistic on a laptop. Override if you want a larger model.
GEMMA_MODEL=gemma3:1b

# Timeout for the app -> Gemma request in milliseconds.
GEMMA_REQUEST_TIMEOUT_MS=45000
